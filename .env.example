# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# JWT Secret for signing tokens (REQUIRED, min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Admin accounts (comma-separated emails)
ADMIN_EMAILS=admin@cenastudio.com.br

# Default passwords for admin and demo users (min 12 chars in production)
ADMIN_DEFAULT_PASSWORD=
DEMO_USER_PASSWORD=

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED FOR PRODUCTION)
# =============================================================================
# Supabase project URL (format: https://<project-ref>.supabase.co)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Frontend environment variables (must have VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: SQLite local database
DATABASE_PATH=./data/frame.db

# Production: Supabase Postgres connection string
# Get from: Supabase Dashboard > Settings > Database > Connection pooling
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1

# Vercel + Supabase Integration (auto-created by integration)
# POSTGRES_PRISMA_URL=<auto-filled-by-vercel-integration>
# POSTGRES_URL=<alternative-connection-string>

# Production safety: set only for controlled beta/testing on ephemeral hosts
ALLOW_EPHEMERAL_SQLITE=false

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================
# Choose your AI provider: openrouter, anthropic, or nvidia
AI_PROVIDER=openrouter

# -----------------------------------------------------------------------------
# OpenRouter (Free tier available - RECOMMENDED)
# -----------------------------------------------------------------------------
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_TOP_P=0.95
OPENROUTER_TIMEOUT_MS=90000
OPENROUTER_FREE_LIMIT=50
FALLBACK_AI_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Anthropic (Paid - Fallback)
# -----------------------------------------------------------------------------
# Get API key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# NVIDIA (Paid - Fallback)
# -----------------------------------------------------------------------------
# Get API key: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Alternative multimodal model:
# NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MAX_TOKENS=4096
NVIDIA_TEMPERATURE=0.7
NVIDIA_TOP_P=0.95
NVIDIA_ENABLE_THINKING=false
NVIDIA_REASONING_BUDGET=0
NVIDIA_TIMEOUT_MS=90000

# =============================================================================
# STRIPE CONFIGURATION (LEGACY/API - OPTIONAL)
# =============================================================================
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_PRO=your_stripe_pro_price_id
STRIPE_PRICE_STUDIO=your_stripe_studio_price_id

# =============================================================================
# GITHUB OAUTH (OPTIONAL)
# =============================================================================
# Create OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# =============================================================================
# CLOUDINARY CONFIGURATION (REQUIRED FOR FILE UPLOADS)
# =============================================================================
# Get credentials: https://console.cloudinary.com/settings/c-/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =============================================================================
# SMTP settings for sending emails (contact form, password reset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
