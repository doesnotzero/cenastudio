# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=
ADMIN_EMAILS=admin@cenastudio.com.br
ADMIN_DEFAULT_PASSWORD=
DEMO_USER_PASSWORD=
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Database
DATABASE_PATH=./data/frame.db

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_PROVIDER=nvidia
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Alternative multimodal model:
# NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MAX_TOKENS=2048
NVIDIA_TEMPERATURE=0.7
NVIDIA_TOP_P=0.95
NVIDIA_ENABLE_THINKING=true
NVIDIA_REASONING_BUDGET=512
NVIDIA_TIMEOUT_MS=60000

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_PRO=your_stripe_pro_price_id
STRIPE_PRICE_STUDIO=your_stripe_studio_price_id

# GitHub OAuth (for admin login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Optional: Email for contact form
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
