{
  "name": "cenastudio",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -k \"NODE_ENV=development PORT=5001 tsx watch server/index.ts\" \"VITE_API_PROXY=http://localhost:5001 vite --host --port 5173\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "start:prod": "npm run start",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "landing:capture": "node scripts/capture-landing-screens.mjs",
    "ci": "npm run check && npm run test:coverage && npm run build",
    "verify": "npm run check && npm run test && npm run build",
    "validate:env": "tsx scripts/validate-env.ts",
    "launch:check": "node scripts/launch-check.mjs",
    "production:smoke": "node scripts/production-auth-smoke.mjs",
    "smoke:prisma": "node scripts/smoke-prisma.mjs",
    "lint": "tsc --noEmit",
    "format": "prettier --write ."
  },
