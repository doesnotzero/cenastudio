{
  "name": "collaborators-teams",
  "version": "1.0.0",
  "description": "Sistema de colaboradores e permissões por projeto",
  "instructions": {
    "routes": "/api/collaborators (authenticate), /api/project-members (authenticate)",
    "controllers": {
      "collaborators": "server/controllers/collaboratorsController.ts",
      "project_members": "server/controllers/projectMembersController.ts"
    },
    "collaborator_endpoints": {
      "list": "GET /api/collaborators",
      "create": "POST /api/collaborators { name, email, role }",
      "update": "PUT /api/collaborators/:id { name?, email?, role?, status? }",
      "delete": "DELETE /api/collaborators/:id",
      "stats": "GET /api/collaborators/stats"
    },
    "project_member_endpoints": {
      "list": "GET /api/project-members/:projectId",
      "add": "POST /api/project-members/:projectId { collaboratorId, permission }",
      "update": "PUT /api/project-members/:projectId/:collaboratorId { permission }",
      "remove": "DELETE /api/project-members/:projectId/:collaboratorId"
    },
    "permissions": {
      "viewer": "Apenas visualizar",
      "editor": "Visualizar e editar",
      "admin": "Controle total sobre o projeto"
    },
    "frontend_pages": {
      "collaborators": "Collaborators.tsx — lista e gerencia membros da equipe"
    }
  }
}
