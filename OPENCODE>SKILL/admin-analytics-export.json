{
  "name": "admin-analytics-export",
  "version": "1.0.0",
  "description": "Painel administrativo, dashboard de analytics e sistema de exportação",
  "instructions": {
    "admin_module": {
      "routes": "/api/admin (authenticate + requireAdmin)",
      "controller": "server/controllers/adminController.ts",
      "endpoints": {
        "list_tools": "GET /api/admin/tools (todas ferramentas, inclusive inativas)",
        "create_tool": "POST /api/admin/tools",
        "update_tool": "PUT /api/admin/tools/:id",
        "delete_tool": "DELETE /api/admin/tools/:id (soft-delete: is_active = 0)",
        "users_count": "GET /api/admin/users { count, online }"
      },
      "frontend": "AdminDashboard.tsx"
    },
    "analytics_module": {
      "routes": "/api/analytics (authenticate)",
      "controller": "server/controllers/analyticsController.ts",
      "endpoints": {
        "overall": "GET /api/analytics/overall — métricas gerais (projetos, clientes, receita, gerações)",
        "project": "GET /api/analytics/projects/:id — métricas por projeto",
        "revenue": "GET /api/analytics/revenue — métricas de receita",
        "activity": "GET /api/analytics/activity — atividade recente"
      },
      "frontend": "Analytics.tsx"
    },
    "export_module": {
      "routes": "/api/export (authenticate)",
      "controller": "server/controllers/exportController.ts",
      "formats": "JSON e CSV (query param ?format=json|csv)",
      "endpoints": {
        "project": "GET /api/export/project/:id",
        "client": "GET /api/export/client/:id",
        "clients": "GET /api/export/clients (todos)",
        "pipeline": "GET /api/export/pipeline"
      }
    },
    "notes": {
      "admin_role": "Apenas usuários com role='admin' podem acessar rotas /api/admin",
      "soft_delete": "Ferramentas são desativadas (is_active=0), não removidas do banco"
    }
  }
}
