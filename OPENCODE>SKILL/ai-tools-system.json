{
  "name": "ai-tools-system",
  "version": "1.0.0",
  "description": "Sistema de 12 ferramentas de IA para produção audiovisual",
  "instructions": {
    "tool_definition": {
      "file": "shared/tools.ts",
      "ids": "01 a 12",
      "structure": {
        "id": "ToolId ('01' | '02' | ... | '12')",
        "slug": "string (url-friendly)",
        "name": "string (display name)",
        "icon": "string (emoji)",
        "description": "string (short description)",
        "category": "string",
        "tags": "string[]",
        "processingTime": "string",
        "placeholder": "string (input placeholder)",
        "promptRole": "string (system prompt para IA)"
      }
    },
    "adding_new_tool": {
      "step_1": "Adicionar entrada no array TOOLS em shared/tools.ts com próximo ID disponível",
      "step_2": "Adicionar novo ID ao tipo ToolId",
      "step_3": "Adicionar ícone correspondente em client/src/lib/toolIcons.tsx se necessário",
      "step_4": "Reiniciar servidor para seed da nova ferramenta no banco"
    },
    "generation_flow": {
      "frontend": "api.ai.generate(toolId, input, projectId) → POST /api/ai/generate",
      "backend_validation": "validateBody(generateSchema) → toolId regex /^([0-1]?[0-9]|20)$/",
      "controller": "aiController.generate → checkAndIncrementUsage + aiService.generateForTool",
      "service": "aiService.generateForTool → constrói prompt com promptRole + input, chama AI provider, salva em generations",
      "provider_selection": "Env AI_PROVIDER: 'nvidia' | 'anthropic'. NVIDIA se NVIDIA_API_KEY configurado, senão Anthropic",
      "usage_limits": "Verifica limite do usuário via planos de assinatura"
    },
    "ai_providers": {
      "anthropic": {
        "api_key": "ANTHROPIC_API_KEY",
        "model": "ANTHROPIC_MODEL (default: claude-sonnet-4-20250514)",
        "function": "generateWithAnthropic(system, userText) → Anthropic SDK"
      },
      "nvidia": {
        "api_key": "NVIDIA_API_KEY",
        "model": "NVIDIA_MODEL (default: nvidia/nemotron-3-ultra-550b-a55b)",
        "url": "NVIDIA_INVOKE_URL (default: https://integrate.api.nvidia.com/v1/chat/completions)",
        "timeout": "NVIDIA_TIMEOUT_MS (default: 60000)",
        "reasoning": "NVIDIA_REASONING_BUDGET (default: 512, 0 para desligar)",
        "function": "generateWithNvidia(system, userText) → fetch REST"
      }
    },
    "tool_list": [
      { "id": "01", "name": "Gerador de Roteiro", "slug": "roteiro", "category": "Pré-produção" },
      { "id": "02", "name": "Decupagem Técnica", "slug": "decupagem", "category": "Direção" },
      { "id": "03", "name": "Callsheet Inteligente", "slug": "callsheet", "category": "Produção" },
      { "id": "04", "name": "Orçamento Automático", "slug": "orcamento", "category": "Comercial" },
      { "id": "05", "name": "Proposta Comercial", "slug": "proposta", "category": "Vendas" },
      { "id": "06", "name": "Contratos", "slug": "contrato", "category": "Jurídico" },
      { "id": "07", "name": "Briefing Inteligente", "slug": "briefing", "category": "Atendimento" },
      { "id": "08", "name": "Moodboard & Look", "slug": "moodboard", "category": "Arte" },
      { "id": "09", "name": "Checklist de Set", "slug": "checklist", "category": "Produção" },
      { "id": "10", "name": "Cronograma", "slug": "cronograma", "category": "Gestão" },
      { "id": "11", "name": "Relatório de Entrega", "slug": "entrega", "category": "Pós-produção" },
      { "id": "12", "name": "Assistente Livre", "slug": "assistente", "category": "IA" }
    ]
  }
}
