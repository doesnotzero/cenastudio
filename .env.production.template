# =============================================================================
# CENA STUDIO - PRODUCTION ENVIRONMENT
# =============================================================================
# ⚠️ NUNCA COMMITAR ESTE ARQUIVO! Ele contém credenciais sensíveis.
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=5000
CLIENT_ORIGIN=https://cenastudio.dev

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Gerar com: openssl rand -base64 32
JWT_SECRET=<GERAR_JWT_SECRET>

# Seus emails de admin (comma-separated)
ADMIN_EMAILS=seu-email@dominio.com

# Senhas fortes (min 12 caracteres)
ADMIN_DEFAULT_PASSWORD=<CRIAR_SENHA_FORTE>
DEMO_USER_PASSWORD=<CRIAR_SENHA_DEMO>

# =============================================================================
# DATABASE (Railway PostgreSQL)
# =============================================================================
# Railway auto-injeta essa variável quando você conecta o Postgres
DATABASE_URL=${{Postgres.DATABASE_URL}}

# =============================================================================
# AI PROVIDER (OpenRouter)
# =============================================================================
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=<CRIAR_CONTA_OPENROUTER>
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.7

# =============================================================================
# STRIPE (Pagamentos)
# =============================================================================
STRIPE_SECRET_KEY=<CRIAR_CONTA_STRIPE>
STRIPE_PUBLISHABLE_KEY=<CRIAR_CONTA_STRIPE>
STRIPE_WEBHOOK_SECRET=<CONFIGURAR_DEPOIS_DO_DEPLOY>
STRIPE_PRICE_PRO=<CRIAR_PRODUTO_PRO>
STRIPE_PRICE_STUDIO=<CRIAR_PRODUTO_STUDIO>

# =============================================================================
# CLOUDINARY (Storage) ✅ CONCLUÍDO
# =============================================================================
CLOUDINARY_CLOUD_NAME=tlfxvneq
CLOUDINARY_API_KEY=616546241273315
CLOUDINARY_API_SECRET=1LR3bMh83L6kLtMxkkdII4HqFfc

# =============================================================================
# SUPABASE (Autenticação Social - OPCIONAL)
# =============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# GITHUB OAUTH (OPCIONAL)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://cenastudio.dev/api/auth/github/callback
